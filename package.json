{
  "name": "nommi",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "seed:demo": "tsx --tsconfig scripts/tsconfig.seed.json scripts/seed/nommiSeed.ts",
    "seed:demo:purge": "tsx --tsconfig scripts/tsconfig.seed.json scripts/seed/nommiSeed.ts --purge-only",
    "seed:demo:reset": "tsx --tsconfig scripts/tsconfig.seed.json scripts/seed/nommiSeed.ts --purge && tsx --tsconfig scripts/tsconfig.seed.json scripts/seed/nommiSeed.ts",
    "seed:demo:export-json": "tsx --tsconfig scripts/tsconfig.seed.json scripts/seed/nommiSeed.ts --export-json",
    "db:link": "supabase link --project-ref \"$SUPABASE_PROJECT_REF\" -p \"$SUPABASE_DB_PASSWORD\" --yes",
    "db:link:direct": "supabase link --project-ref \"$SUPABASE_PROJECT_REF\" -p \"$SUPABASE_DB_PASSWORD\" --skip-pooler --yes",
    "db:push": "supabase db push",
    "db:apply": "bash scripts/apply-migrations.sh",
    "db:reload-schema": "supabase db query --linked \"NOTIFY pgrst, 'reload schema';\""
  },
  "dependencies": {
    "@googlemaps/js-api-loader": "^2.0.2",
    "@supabase/supabase-js": "^2.105.1",
    "@tailwindcss/vite": "^4.2.4",
    "date-fns": "^4.1.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.11.0",
    "dotenv": "^16.6.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.14.2",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/google.maps": "^3.64.0",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "postcss": "^8.5.12",
    "supabase": "^2.98.2",
    "tsx": "^4.21.0",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10"
  }
}
